<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite">
	<groups>
		<run>
			<include name="organization"/>
			<include name="contact"/>
		</run>
	</groups>
	
	<listeners>
		<listener class-name="listeners.TestListener"></listener>
	</listeners>
  <test thread-count="5" name="Test">
    <classes>
      <class name="contactModule.CreateContactWithOrganization"/>
      <class name="contactModule.CreateContactWithSupportDates"/>
      <class name="organizationModule.CreateOrgTest"/>
      <class name="organizationModule.CreateOrgWithIndustryAndType"/>
      <class name="organizationModule.CreateOrgWithPhoneNumber"/>
      <class name="contactModule.CreateContactTest"/>
    </classes>
  </test> <!-- Test -->
</suite> <!-- Suite -->
