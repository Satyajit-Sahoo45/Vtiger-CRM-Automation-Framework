<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite">
	<groups>
		<run>
			<include name="organization"/>
			<include name="contact"/>
		</run>
	</groups>
	
	<listeners>
		<listener class-name="listeners.TestListener"></listener>
	</listeners>
  <test thread-count="5" name="Test">
  	<parameter name="browser" value="chrome"></parameter>
    <classes>
      <class name="organizationModule.OrganizationModuleTest"/>
      <class name="contactModule.ContactModuleTest"/>
    </classes>
  </test> <!-- Test -->
</suite> <!-- Suite -->
